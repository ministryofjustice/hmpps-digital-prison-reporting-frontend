{% extends "./base.njk" %}

{%- from "node_modules/@ministryofjustice/frontend/moj/components/side-navigation/macro.njk" import mojSideNavigation %}
{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}

{% block content %}
  <div class="govuk-width-container govuk-grid-row app-flex-container">
    <div class="govuk-grid-column-one-quarter dpr-docs-sidebar">
      {% include "./partials/side-navigation/dashboards/guides.njk" %}
      {% include "./partials/side-navigation/dashboards/visualisations.njk" %}
    </div>

    <div class="govuk-grid-column-three-quarters">
      <main id="main-content" class="govuk-main-wrapper app-prose-scope" role="main">
        {% if phase %}
          {% set text = 'This feature is in ' + phase +'. Some behaviors may be unstable, and we’re actively working to improve the experience.'%}
          {% if phaseText %}
            {% set text = phaseText %}
          {% endif %}
          <div class="govuk-!-margin-bottom-6">
            {{ govukPhaseBanner({
              tag: { text: phase },
              html: text
            }) }}
          </div>
        {% endif %}

        <h1 class="govuk-heading-xl">
          {% if not isIndex %}
            {% if subsection %}<span class="govuk-caption-xl">{{ subsection }}</span>{% endif %}
          {% endif %}
          {{ title }}
        </h1>
        {{ content | safe }}
        {% block exampleContent %}{% endblock %}
      </main>
    </div>
  </div>
{% endblock %}
