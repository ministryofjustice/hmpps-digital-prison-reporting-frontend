{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/details/macro.njk" import govukDetails %}

{% macro dprFiltersSaveDefaults(action, hasDefaults) %}

  <div class="dpr-async-save-defaults-action">
    {% set text = 'Save current filter values as defaults' %}

    {% if hasDefaults %}
      <p class="govuk-body-xs govuk-!-margin-bottom-2">Your saved default filter values have been applied to this form.</p>
      {% set text = 'Update defaults' %}
    {% endif %}

    {{ govukButton({
      text: text,
      classes: "dpr-clear-button-styles govuk-link govuk-link--no-visited-state",
      attributes: {
        formaction: action + '/save-defaults'
      }
    }) }}
    
    {% if hasDefaults %}
      {{ govukButton({
        text: 'Delete defaults',
        classes: "dpr-clear-button-styles govuk-link govuk-link--no-visited-state",
        attributes: {
          formaction: action + '/remove-defaults'
        }
      }) }}
    {% endif %}
  </div>
{% endmacro %}
