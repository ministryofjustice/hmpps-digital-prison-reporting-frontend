{% from "../dashboard-sidebar/view.njk" import dprDashboardSidebar %}
{% from "../dashboard-filters/view.njk" import dprDashboardFilters %}
{% from "../dashboard-section/view.njk" import dprDashboardSection %}

{% from "../../_charts/chart-card/view.njk" import dprChartCard %}
{% from "../../_reports/report-heading/view.njk" import dprReportHeading %}

{%- from "moj/components/side-navigation/macro.njk" import mojSideNavigation -%}

{% macro dprDashboard(data, validationErrors) %}
  {% set appliedFilters = data.appliedFilters %}
  {% set csrfToken = data.csrfToken %}
  {% set filters = data.filters %}
  {% set sections = data.sections %}

  <div class="dashboard-wrapper">
    
    <nav class="dashboard-sidebar">
      {{ dprDashboardSidebar(sections) }}
    </nav> 

    <div class="dashboard-content">
      {{ dprReportHeading(data) }}
      {{ dprDashboardFilters(filters, validationErrors, appliedFilters, csrfToken) }}
      {% for section in sections %}
        {{ dprDashboardSection(section, loop.index) }}
      {% endfor %}
    </div>
  </div>
{% endmacro %}
