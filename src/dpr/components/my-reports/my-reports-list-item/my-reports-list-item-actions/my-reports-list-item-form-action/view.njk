{% from "../../../../button-link/view.njk" import dprButtonLink %}

{% macro dprMyReportListItemFormAction(formConfig) %}
  {% set action = remove.action %}
  {% set csrfToken = remove.csrfToken %}
  {% set returnTo = remove.returnTo %}
  {% set text = remove.text %}

  {% set classes = 'dpr-button-link govuk-link govuk-link--no-visited-state' %}
  <form method="post" action="{{ action }}" data-remove-report-form>
    <input type="hidden" name="returnTo" value="{{ returnTo }}" />
    <input type="hidden" name="_csrf" value="{{ csrfToken }}" />

    {{
      dprButtonLink({
        text: text,
        classes: classes
      })
    }}
  </form>
{% endmacro %}
