{% from "govuk/components/button/macro.njk" import govukButton %}

{% macro dprMyReportListItemRemoveAction(remove) %}
  {% set action = remove.action %}
  {% set action = remove.csrfToken %}
  
  {% set classes = 'dpr-clear-button-styles govuk-link govuk-link--no-visited-state govuk-!-margin-bottom-1 govuk-!-margin-top-1' %}
  
  <form method='post' action='{{ action }}'>
    <input type="hidden" name="_csrf" value="{{ csrfToken }}">

    {{ govukButton({
      text: 'Remove',
      classes: classes
    }) }}
  </form>
{% endmacro %}
