{% from "../my-reports-list-headings/view.njk" import dprMyReportListHeadings %}
{% from "../my-reports-list-help/view.njk" import dprMyReportsListHelp %}
{% from "../my-reports-list-totals/view.njk" import dprMyReportsListTotals %}

{% macro dprMyReportList(listConfig) %}
  {% set title = listConfig.title %}

  {% set headings = listConfig.headings %}
  {% set items = listConfig.items %}
  {% set totals = listConfig.totals %}
  {% set listType = listConfig.listType %}
  {% set csrfToken = listConfig.csrfToken %}

  {% set classes = 'dpr-my-reports__table--requests' %}
  {% if listType == 'bookmarks' %}
    {% set classes = 'dpr-my-reports__table--bookmarks' %}
  {% endif %}

  <div>
    <h1 class="govuk-heading-m govuk-!-margin-bottom-0">{{ title }}</h1>

    {# Help text #}
    {{ dprMyReportsListHelp(listType) }}

    {% if items | length %}

      {{ dprMyReportsListTotals(totals) }}

      {# THE ITEMS #}
      <div class="dpr-my-reports" data-dpr-module="dpr-my-reports" data-list-type='my-reports-{{ listType }}' data-csrf-token="{{ csrfToken }}">
        <div class="dpr-my-reports__table {{ classes }}">
          
          {# Header row #}
          {{ dprMyReportListHeadings(headings, listType) }}

          {# Body rows #}
          {% for item in items %}
            {% include "../my-reports-list-item/row.njk" %}
          {% endfor %}

        </div>
      </div>

    {% else %}

      <p class='govuk-body'>You have 0 {{ listType }} reports<p>

    {% endif %}
  </div>
{% endmacro %}
