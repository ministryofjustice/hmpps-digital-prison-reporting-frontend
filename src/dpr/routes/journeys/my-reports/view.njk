{% extends layoutPath %}

{% from "../../../components/_catalogue/catalogue-list/view.njk" import dprCatalogueList %}
{% from "../../../components/_catalogue/catalogue-filters/view.njk" import dprCatalogueFilters %}

{% set mainClasses = "app-container govuk-body" %}

{% block content %}
  <div class="govuk-width-container">
    <h1 class="govuk-heading-l">{{ title }}</h1>
    <div id="{{ id }}">
      {{ dprCatalogueFilters(id, features) }}
      {{ dprCatalogueList(id, tableData) }}
    </div>
  </div>
{% endblock %}
