{% from "moj/components/header/macro.njk" import mojHeader %}
{% extends "moj/template.njk" %}
{% from "components/card-group/view.njk" import dprCardGroup %}
{% set mainClasses = "app-container govuk-body" %}

{% block pageTitle %}Test App{% endblock %}

{% block head %}
  <link href="{{ '/assets/css/app.css' | assetMap }}" rel="stylesheet" />

  {% for js in feComponents.jsIncludes %}
    <script src="{{ js }}" nonce="{{ cspNonce }}"></script>
  {% endfor %}

  {% for css in feComponents.cssIncludes %}
    <link href="{{ css }}" nonce="{{ cspNonce }}" rel="stylesheet" />
  {% endfor %}

  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" />
{% endblock %}

{% block header %}
  {{
    mojHeader({
      organisationLabel: {
        text: 'Digital Prison Services',
        href: '/'
      },
      serviceLabel: {
        text: 'Reporting Frontend',
        href: '/'
      },
      containerClasses: "govuk-width-container"
    })
  }}
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ '/assets/js/app.js' | assetMap }}"></script>
{% endblock %}
